generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("admins")
}

model Class {
  id          String   @id @default(uuid())
  title       String
  path        String   @unique
  order       Int      @default(0)
  isPublished Boolean  @default(true) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  topics      Topic[]

  @@map("classes")
}

model Topic {
  id          String   @id @default(uuid())
  classId     String   @map("class_id")
  title       String
  path        String
  content     String
  order       Int      @default(0)
  isPublished Boolean  @default(true) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([classId, path])
  @@map("topics")
}
