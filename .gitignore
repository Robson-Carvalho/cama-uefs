# ============================================================
# OBI UEFS — .gitignore
# Cobre: backend (Node.js/NestJS/TypeScript) +
#         frontend (Vite/React/TypeScript/Tailwind)
# ============================================================

# ------------------------------------------------------------
# Variáveis de ambiente
# ------------------------------------------------------------
.env
.env.local
.env.development
.env.production
.env.test
.env.*.local
!.env.example

# ------------------------------------------------------------
# Dependências
# ------------------------------------------------------------
node_modules/

# ------------------------------------------------------------
# Build — Backend (NestJS / TypeScript)
# ------------------------------------------------------------
backend/dist/
backend/build/

# ------------------------------------------------------------
# Build — Frontend (Vite / React)
# ------------------------------------------------------------
frontend/dist/
frontend/build/
frontend/.vite/

# ------------------------------------------------------------
# TypeScript
# ------------------------------------------------------------
*.tsbuildinfo

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ------------------------------------------------------------
# Testes / Coverage
# ------------------------------------------------------------
coverage/
*.lcov
.nyc_output/

# ------------------------------------------------------------
# Cache de ferramentas
# ------------------------------------------------------------
.eslintcache
.stylelintcache
.parcel-cache/
.cache/

# ------------------------------------------------------------
# Docker (artefatos locais)
# ------------------------------------------------------------
docker-compose.override.yml

# ------------------------------------------------------------
# Sistema operacional
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------
# Editores / IDEs
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
